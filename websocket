#!/bin/bash

# Check if Node.js is installed
if ! command -v node &> /dev/null
then
    echo "Node.js is not installed. Installing..."
    sudo apt update
    sudo apt install -y nodejs npm
else
    echo "Node.js is already installed"
fi

# Install necessary NPM packages (ws and Certbot if not installed)
echo "Installing required npm packages (ws)..."
npm install -g ws

# Install Certbot for SSL (Let’s Encrypt)
echo "Installing Certbot..."
sudo apt install -y certbot

# Request SSL certificate from Let’s Encrypt
echo "Requesting SSL certificate..."
sudo certbot certonly --standalone -d your-domain.com

# Create WebSocket server file (ws_server.js)
echo "Creating WebSocket server script..."

cat <<EOL > ws_server.js
#!/usr/bin/env node

const fs = require('fs');
const https = require('https');
const WebSocket = require('ws');

// SSL certificate paths (make sure tama ang path mo)
const sslOptions = {
    cert: fs.readFileSync('/etc/letsencrypt/live/your-domain.com/fullchain.pem'),
    key: fs.readFileSync('/etc/letsencrypt/live/your-domain.com/privkey.pem')
};

// Create HTTPS server
const server = https.createServer(sslOptions);

// Create WebSocket server
const wss = new WebSocket.Server({ server });

wss.on('connection', (ws) => {
    console.log('Client connected via wss://');

    // Send message kapag nakakonekta
    ws.send('Hello, you are securely connected to the WebSocket server!');

    // Receive message mula sa client
    ws.on('message', (message) => {
        console.log('Received: %s', message);
        ws.send(\`You said: \${message}\`);
    });

    // Close event
    ws.on('close', () => {
        console.log('Client disconnected');
    });
});

// Listen sa port 8080
server.listen(8080, () => {
    console.log('Secure WebSocket server running on wss://your-domain.com:8080');
});
EOL

# Make ws_server.js executable
chmod +x ws_server.js

# Run the WebSocket server
echo "Starting WebSocket server..."
node ws_server.js

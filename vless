#!/bin/bash

# Function to add color
function print_color {
  COLOR=$1
  MESSAGE=$2
  NC='\033[0m' # No Color
  case $COLOR in
    "red")
      echo -e "\033[0;31m${MESSAGE}${NC}"
      ;;
    "green")
      echo -e "\033[0;32m${MESSAGE}${NC}"
      ;;
    "yellow")
      echo -e "\033[0;33m${MESSAGE}${NC}"
      ;;
    "blue")
      echo -e "\033[0;34m${MESSAGE}${NC}"
      ;;
    *)
      echo "${MESSAGE}"
      ;;
  esac
}

# Function to create a VLESS user
create_vless_user() {
  # Generate a new UUID for the VLESS user
  UUID=$(uuidgen)
  
  # Define VLESS client config path
  VLESS_CONFIG_PATH="/etc/xray/vless_clients.json"

  # Prompt for the VLESS user name (optional)
  read -p "Enter a name for the VLESS user (e.g., user1): " vless_username
  echo "Creating VLESS account for $vless_username with UUID: $UUID"
  
  # Check if the VLESS client file exists, if not, create it
  if [ ! -f "$VLESS_CONFIG_PATH" ]; then
    sudo touch "$VLESS_CONFIG_PATH"
  fi

  # Add the new VLESS client details to the VLESS config file
  sudo jq --arg username "$vless_username" --arg uuid "$UUID" \
    '.inbounds[0].settings.clients += [{"id": $uuid, "alterId": 0, "security": "none", "email": $username}]' \
    "$VLESS_CONFIG_PATH" > tmp.json && mv tmp.json "$VLESS_CONFIG_PATH"

  # Display the newly created VLESS client information
  print_color "green" "VLESS user '$vless_username' created successfully!"
  print_color "blue" "VLESS Client Details:"
  echo "============================="
  echo "Username: $vless_username"
  echo "UUID: $UUID"
  echo "VLESS Configuration Path: $VLESS_CONFIG_PATH"
  echo "============================="
}

# Main menu loop
while true; do
    clear
    print_color "blue" "==== Main Menu ===="
    echo "1) Create new VLESS user account"
    echo "2) Quit"
    read -p "Choose option [1-2]: " choice
    case $choice in
        1) create_vless_user; read -p "Press Enter to return to menu...";;
        2) print_color "red" "Exiting..."; exit 0;;
        *) print_color "red" "Invalid choice!"; sleep 1;;
    esac
done

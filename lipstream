#!/usr/bin/env bash
set -euo pipefail

# ─── Slipstream + Dante SOCKS Setup ───
# One-liner: curl -sSL https://raw.githubusercontent.com/dnstt-xyz/slipstream-socks-deploy/main/install.sh | bash -s -- --domain t.example.com
# Or: wget -qO- ... | bash -s -- --domain t.example.com

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[x]${NC} $*" >&2; exit 1; }

# ─── Pinned commit ───
PINNED_COMMIT="bc772dd07d9a136dbd7553b0da575526de207847"

# ─── Defaults ───
DOMAIN=""
DNS_PORT=53
SOCKS_PORT=1080
INSTALL_DIR="/opt/slipstream-rust"
CERT_DIR="/opt/slipstream-rust"

usage() {
    cat <<EOF
Usage: $0 --domain <tunnel-domain> [OPTIONS]

Required:
  --domain DOMAIN       DNS tunnel domain (e.g. t.dnstt.xyz)

Options:
  --dns-port PORT       DNS listen port (default: 53)
  --socks-port PORT     Dante SOCKS port (default: 1080)
  --install-dir DIR     Install directory (default: /opt/slipstream-rust)
  --uninstall           Remove everything
  -h, --help            Show this help
EOF
    exit 0
}

uninstall() {
    log "Uninstalling slipstream + dante..."
    systemctl stop slipstream 2>/dev/null || true
    systemctl disable slipstream 2>/dev/null || true
    rm -f /etc/systemd/system/slipstream.service
    systemctl stop danted 2>/dev/null || true
    apt-get remove -y dante-server 2>/dev/null || true
    rm -rf "$INSTALL_DIR"
    systemctl daemon-reload
    log "Uninstalled."
    exit 0
}

# ─── Parse args ───
while [[ $# -gt 0 ]]; do
    case "$1" in
        --domain)      DOMAIN="$2"; shift 2 ;;
        --dns-port)    DNS_PORT="$2"; shift 2 ;;
        --socks-port)  SOCKS_PORT="$2"; shift 2 ;;
        --install-dir) INSTALL_DIR="$2"; CERT_DIR="$2"; shift 2 ;;
        --uninstall)   uninstall ;;
        -h|--help)     usage ;;
        *)             err "Unknown option: $1" ;;
    esac
done

[[ -z "$DOMAIN" ]] && err "Missing required --domain. Run with --help for usage."
[[ $(id -u) -ne 0 ]] && err "Must run as root."

# ─── Check OS ───
if ! grep -qi ubuntu /etc/os-release 2>/dev/null; then
    warn "This script is designed for Ubuntu. Proceed at your own risk."
fi

# ─── Stop conflicting services on port 53 ───
if ss -tulnp 2>/dev/null | grep -q ":${DNS_PORT} "; then
    log "Port $DNS_PORT in use. Checking for systemd-resolved..."
    if systemctl is-active --quiet systemd-resolved 2>/dev/null; then
        log "Stopping systemd-resolved..."
        systemctl stop systemd-resolved
        systemctl disable systemd-resolved
        # Set a static nameserver so the system can still resolve
        if [[ ! -f /etc/resolv.conf.bak ]]; then
            cp /etc/resolv.conf /etc/resolv.conf.bak 2>/dev/null || true
        fi
        echo "nameserver 8.8.8.8" > /etc/resolv.conf
        echo "nameserver 1.1.1.1" >> /etc/resolv.conf
        log "systemd-resolved disabled. Static DNS set."
    else
        err "Port $DNS_PORT is in use by another process. Free it first."
    fi
fi

# ─── Install system dependencies ───
log "Installing system packages..."
export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq build-essential cmake pkg-config libssl-dev git python3 curl dante-server >/dev/null 2>&1
log "System packages installed."

# ─── Install Rust ───
if ! command -v cargo &>/dev/null; then
    log "Installing Rust..."
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y >/dev/null 2>&1
    source "$HOME/.cargo/env"
    log "Rust installed."
else
    source "$HOME/.cargo/env" 2>/dev/null || true
    log "Rust already installed."
fi

# ─── Clone and build slipstream ───
if [[ -d "$INSTALL_DIR/.git" ]]; then
    log "Existing install found at $INSTALL_DIR"
    cd "$INSTALL_DIR"
else
    log "Cloning slipstream-rust..."
    rm -rf "$INSTALL_DIR"
    git clone --quiet https://github.com/Mygod/slipstream-rust.git "$INSTALL_DIR"
    cd "$INSTALL_DIR"
fi

log "Checking out pinned commit ${PINNED_COMMIT:0:12}..."
git fetch --quiet origin
git checkout --quiet "$PINNED_COMMIT"
git submodule update --init --recursive --quiet

COMMIT_HASH=$(git rev-parse --short HEAD)
COMMIT_MSG=$(git log -1 --pretty=format:"%s")
COMMIT_DATE=$(git log -1 --pretty=format:"%ci")
log "Slipstream commit: ${COMMIT_HASH} - ${COMMIT_MSG} (${COMMIT_DATE})"

log "Building slipstream-server (this may take a few minutes)..."
cargo build --release -p slipstream-server --quiet 2>&1
log "Build complete."

# ─── Detect external IP for Dante ───
# Use the IP address directly instead of interface name for VPS compatibility
# (venet/OpenVZ interfaces fail with interface names in Dante)
EXT_IP=$(ip -4 addr show scope global 2>/dev/null | awk '/inet/{print $2}' | cut -d/ -f1 | head -1)
if [[ -z "$EXT_IP" ]]; then
    EXT_IP=$(curl -s --max-time 5 ifconfig.me 2>/dev/null)
fi
[[ -z "$EXT_IP" ]] && err "Could not detect external IP address."
log "Detected external IP: $EXT_IP"

# ─── Configure Dante SOCKS proxy ───
log "Configuring Dante SOCKS proxy on 127.0.0.1:${SOCKS_PORT}..."
cat > /etc/danted.conf <<EOF
logoutput: syslog

internal: 127.0.0.1 port = ${SOCKS_PORT}
external: ${EXT_IP}

socksmethod: none
clientmethod: none

client pass {
    from: 127.0.0.1/32 to: 0.0.0.0/0
    log: connect disconnect error
}

socks pass {
    from: 127.0.0.1/32 to: 0.0.0.0/0
    protocol: tcp udp
    log: connect disconnect error
}
EOF

systemctl restart danted
systemctl enable danted >/dev/null 2>&1
log "Dante SOCKS proxy running."

# ─── Configure slipstream systemd service ───
log "Creating slipstream systemd service..."
cat > /etc/systemd/system/slipstream.service <<EOF
[Unit]
Description=Slipstream DNS Tunnel Server
After=network.target danted.service

[Service]
Type=simple
ExecStart=${INSTALL_DIR}/target/release/slipstream-server \\
    --dns-listen-port ${DNS_PORT} \\
    --target-address 127.0.0.1:${SOCKS_PORT} \\
    --domain ${DOMAIN} \\
    --cert ${CERT_DIR}/cert.pem \\
    --key ${CERT_DIR}/key.pem \\
    --reset-seed ${CERT_DIR}/reset-seed
WorkingDirectory=${INSTALL_DIR}
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable slipstream >/dev/null 2>&1
systemctl restart slipstream
sleep 2

if systemctl is-active --quiet slipstream; then
    log "Slipstream server running."
else
    err "Slipstream failed to start. Check: journalctl -u slipstream --no-pager -n 20"
fi

# ─── Print summary ───
SERVER_IP=$(curl -s --max-time 5 ifconfig.me 2>/dev/null || ip -4 addr show scope global | awk '/inet /{print $2}' | cut -d/ -f1 | head -1)

echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}  Slipstream + Dante Setup Complete${NC}"
echo -e "${GREEN}════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  Server IP:     ${YELLOW}${SERVER_IP}${NC}"
echo -e "  Tunnel domain: ${YELLOW}${DOMAIN}${NC}"
echo -e "  DNS port:      ${DNS_PORT}"
echo -e "  SOCKS port:    ${SOCKS_PORT} (localhost only)"
echo -e "  Slipstream:    ${YELLOW}${COMMIT_HASH}${NC} - ${COMMIT_MSG} (${COMMIT_DATE})"
echo ""
echo -e "${YELLOW}  DNS Records Required:${NC}"
echo -e "  ┌─────────┬──────────┬──────────────────┐"
echo -e "  │ Type    │ Name     │ Value            │"
echo -e "  ├─────────┼──────────┼──────────────────┤"

# Extract subdomain and parent from DOMAIN
PARENT=$(echo "$DOMAIN" | cut -d. -f2-)
SUB=$(echo "$DOMAIN" | cut -d. -f1)

echo -e "  │ A       │ ns       │ ${SERVER_IP}  │"
echo -e "  │ NS      │ ${SUB}$(printf '%*s' $((8-${#SUB})) '')│ ns.${PARENT}$(printf '%*s' $((16-3-${#PARENT})) '')│"
echo -e "  └─────────┴──────────┴──────────────────┘"
echo ""
echo -e "${YELLOW}  Client usage:${NC}"
echo -e "  slipstream-client --tcp-listen-port 7000 --domain ${DOMAIN}"
echo -e "  Then: curl -x socks5h://127.0.0.1:7000 http://ifconfig.me"
echo ""
echo -e "${YELLOW}  Management:${NC}"
echo -e "  systemctl status slipstream    # check server"
echo -e "  systemctl status danted        # check SOCKS proxy"
echo -e "  journalctl -fu slipstream      # follow server logs"
echo -e "  bash install.sh --uninstall    # remove everything"
echo ""

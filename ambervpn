#!/bin/bash
# =========================================
# Custom VPS Setup | Automated Script
# Edition : Stable Edition V1.0
# Author  : AMBERVPN
# (C) Copyright 2022
# =========================================

# Clear terminal and set up color codes
clear
DEFBOLD='\e[39;1m'
RB='\e[31;1m'
GB='\e[32;1m'
YB='\e[33;1m'
BB='\e[34;1m'
MB='\e[35;1m'
CB='\e[35;1m'
WB='\e[37;1m'
red='\e[1;31m'
green='\e[0;32m'
purple='\e[0;35m'
orange='\e[0;33m'
NC='\e[0m'

# Check if the script is being run as root
if [ "${EUID}" -ne 0 ]; then
    echo "You need to run this script as root"
    exit 1
fi

# Check for OpenVZ virtualization
if [ "$(systemd-detect-virt)" == "openvz" ]; then
    echo "OpenVZ is not supported"
    exit 1
fi

# Fetch the public IP of the server
MYIP=$(wget -qO- ipv4.icanhazip.com)

echo "Checking VPS IP..."
clear

# Set up directories for the script
mkdir /var/lib/premium-script
mkdir /var/lib/crot-script

# Set the server URL for downloading files
export Server_URL="raw.githubusercontent.com/NevermoreSSH/yourpath/main"

# Display domain options
clear
echo -e "${red}    ♦️${NC} ${green} CUSTOM SETUP DOMAIN VPS     ${NC}"
echo -e "${red}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo "1. Use Domain From Script"
echo "2. Choose Your Own Domain"
echo -e "${red}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Get user's domain choice
read -rp "Choose Your Domain Installation: " dom

# Based on the user's choice, run corresponding logic
if test $dom -eq 1; then
    clear
    wget -q -O /root/cf.sh "https://${Server_URL}/cf.sh"
    chmod +x /root/cf.sh
    ./cf.sh
elif test $dom -eq 2; then
    read -rp "Enter Your Domain: " domen
    echo $domen > /root/domain
else
    echo "Invalid choice"
    exit 1
fi

echo -e "${green}Domain setup done!${NC}"
sleep 2
clear

# Record the VPS IP
echo "IP=$MYIP" >> /var/lib/premium-script/ipvps.conf
echo "IP=$MYIP" >> /var/lib/crot-script/ipvps.conf
echo "$MYIP" >> /root/domain

# Install dependencies
echo -e "\e[0;32mInstalling Dependencies...\e[0m"
apt update
apt install -y git curl

# Install SSH-VPN
echo -e "\e[0;32mINSTALLING SSH-VPN...\e[0m"
sleep 1
wget -q -O /root/ssh-vpn.sh "https://${Server_URL}/ssh-vpn.sh"
chmod +x /root/ssh-vpn.sh
./ssh-vpn.sh
sleep 3

# Install Xray Core
echo -e "\e[0;32mINSTALLING XRAY CORE...\e[0m"
sleep 3
wget -q -O /root/xray.sh "https://${Server_URL}/xray.sh"
chmod +x /root/xray.sh
./xray.sh
echo -e "${green}Xray installation complete!${NC}"
sleep 2

# Install Set-BR script (likely related to bandwidth or resources)
echo -e "\e[0;32mINSTALLING SET-BR...\e[0m"
sleep 1
wget -q -O /root/set-br.sh "https://${Server_URL}/set-br.sh"
chmod +x /root/set-br.sh
./set-br.sh
echo -e "${green}Set-BR installation complete!${NC}"
sleep 2

# Cleanup downloaded scripts
echo -e "\e[0;32mCleaning up temporary files...\e[0m"
rm -f /root/ssh-vpn.sh
rm -f /root/xray.sh
rm -f /root/set-br.sh

# Final message
clear
echo -e "${red}-------------------------------------------${NC}"
echo -e "${green}Installation Complete!${NC}"
echo -e "${red}-------------------------------------------${NC}"
echo -e "${green}VPS Setup is ready to use with SSH-VPN and Xray.${NC}"
echo -e "${green}Enjoy your new setup!${NC}"

# End script
